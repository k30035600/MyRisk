# 프로젝트 lib 패키지 포함 (가상환경 Lib/와 구분; Windows에서 Lib/가 lib/까지 무시하므로 예외)
!/lib/
# lib 아래 site-packages 등 제외 (프로젝트 소스만 푸시)
lib/site-packages/
lib/*.dist-info/

